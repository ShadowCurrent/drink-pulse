# ──────────────────────────────────────────────
# macOS
# ──────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# Spotlight
.Spotlight-V100

# Trashes
.Trashes
.fseventsd

# ──────────────────────────────────────────────
# Xcode — user-specific, never shared
# ──────────────────────────────────────────────
xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# Legacy Xcode file-format artefacts
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xccheckout
*.moved-aside
*.xcuserstate

# ──────────────────────────────────────────────
# Xcode — keep shared schemes, ignore generated ones
# ──────────────────────────────────────────────
# xcshareddata/xcschemes/ is intentionally NOT ignored —
# shared schemes should be committed so CI and teammates
# can build the same targets.

# ──────────────────────────────────────────────
# Swift Package Manager
# ──────────────────────────────────────────────
.build/
.swiftpm/xcode/
# Package.resolved IS committed — it pins exact dependency versions.
# Delete this line only if you intentionally want floating deps.

# ──────────────────────────────────────────────
# Build output (custom derivedDataPath)
# ──────────────────────────────────────────────
build/
*.xcresult

# ──────────────────────────────────────────────
# Code signing / provisioning
# ──────────────────────────────────────────────
*.p12
*.cer
*.mobileprovision
*.certSigningRequest
ExportOptions.plist

# ──────────────────────────────────────────────
# Instruments / profiling
# ──────────────────────────────────────────────
*.trace
*.dtps

# ──────────────────────────────────────────────
# Playgrounds
# ──────────────────────────────────────────────
timeline.xctimeline
playground.xcworkspace

# ──────────────────────────────────────────────
# Simulators
# ──────────────────────────────────────────────
*.app/

# ──────────────────────────────────────────────
# Fastlane (if added later)
# ──────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/
fastlane/readme.md

# ──────────────────────────────────────────────
# Env / secrets
# ──────────────────────────────────────────────
.env
.env.*
*.secret
secrets.plist

# ──────────────────────────────────────────────
# Editor artefacts
# ──────────────────────────────────────────────
# VS Code / Cursor
.vscode/

# JetBrains
.idea/

# ──────────────────────────────────────────────
# Claude Code — machine-specific and ephemeral
# ──────────────────────────────────────────────
.claude/settings.local.json

# GSD — machine-specific install bookkeeping (timestamps, checksums per
# local install run). The tool payload itself (agents/, commands/,
# gsd-core/, hooks/, scripts/, package.json) IS committed so the team
# shares the same GSD setup.
.claude/gsd-install-state.json
.claude/gsd-migration-journal/
.claude/gsd-file-manifest.json

# ──────────────────────────────────────────────
# Project-specific data files
# ──────────────────────────────────────────────
# Migration source from DrinkControl — personal data, never commit
drinkcontrol.csv
# DrinkPulse export/backup bundles — full user health history, never commit
drinkpulse-backup-*.json

# ──────────────────────────────────────────────
# graphify — large generated graph artefacts, regenerable
# ──────────────────────────────────────────────
.planning/graphs/graph.json
.planning/graphs/graph.html
.planning/graphs/.last-build-snapshot.json
